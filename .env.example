NODE_ENV=development
PORT=5000

# JWT
JWT_SECRET=replace_with_a_long_random_secret

# CORS
# Comma-separated list. Example:
# CORS_ORIGIN=http://localhost:5173,https://app.example.com
CORS_ORIGIN=http://localhost:5173

# MySQL / RDS
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=replace_with_db_password
DB_NAME=trainer_assessment_db
DB_CONNECTION_LIMIT=10

# Set true for managed DBs that require TLS (for example, AWS RDS with SSL policy).
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# SMTP (required for forgot-password OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_with_smtp_username
SMTP_PASS=replace_with_smtp_password_or_app_password
SMTP_FROM=Trainer Assessment <no-reply@example.com>

# Password reset OTP settings
PASSWORD_RESET_OTP_MINUTES=10
PASSWORD_RESET_OTP_COOLDOWN_SECONDS=60
PASSWORD_RESET_OTP_MAX_ATTEMPTS=5
PASSWORD_RESET_SESSION_MINUTES=15
PASSWORD_RESET_MIN_PASSWORD_LENGTH=8
# Optional extra secret for hashing OTP values at rest
PASSWORD_RESET_OTP_SECRET=replace_with_random_secret
